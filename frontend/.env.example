# Sui network — "mainnet" | "testnet" | "devnet"
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Walrus mainnet endpoints. Leave blank to run in demo adapter mode.
# Publisher writes blobs; aggregator reads them.
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=

# Sui package ID of the published sc_signalvault Move package.
# When set, the frontend issues real PTBs for create_form / record_response.
NEXT_PUBLIC_SIGNALVAULT_PACKAGE_ID=

# Seal package ID. When set, the frontend uses real Seal SDK; otherwise demo adapter.
NEXT_PUBLIC_SEAL_PACKAGE_ID=

# Canonical app URL — used to build shareable form links and receipt links.
NEXT_PUBLIC_APP_URL=https://signalvault.ezidentity.wal.app
